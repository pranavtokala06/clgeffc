{
  "compilerOptions": {
    "target": "ES2018",
    "outDir": "dist",
    "rootDir": ".",
    "lib": ["ES2018", "DOM"],
    "types": ["node"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src", "prisma"]
}




  
  
  
   
